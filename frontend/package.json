{
  "name": "bridge-defect-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:types": "sh -c 'PY=../backend/.venv-yolo/bin/python; [ -x \"$PY\" ] || PY=../backend/.venv/bin/python; [ -x \"$PY\" ] || PY=python3; \"$PY\" ../scripts/generate_openapi_schema.py && openapi-typescript ../artifacts/openapi/frontend-openapi.json -o ./src/lib/api/generated.ts'"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  }
}
