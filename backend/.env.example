BDI_MODEL_NAME=yolov8-seg
BDI_MODEL_VERSION=v1-real
BDI_MODEL_BACKEND=pytorch
BDI_MAX_UPLOAD_SIZE_BYTES=31457280
BDI_MODEL_WEIGHTS_PATH=/absolute/path/to/your-model.pt
BDI_MODEL_DEVICE=cpu
BDI_MODEL_IMGSZ=1280
BDI_ALLOW_MOCK_FALLBACK=true
BDI_EXTRA_MODELS=[{"model_version":"mock-v2","backend":"mock","runner_kind":"mock"},{"model_version":"v2-real","backend":"pytorch","weights_path":"/absolute/path/to/another-model.pt"}]
BDI_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
